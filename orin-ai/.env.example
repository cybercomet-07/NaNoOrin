# =============================================================================
# Orin AI — environment template
# Copy to backend/.env (see orin-ai/README.md). Never commit real secrets.
# =============================================================================
#
# ENVIRONMENT TIERS (see README.md "Environments")
# - Development: placeholders or test keys OK; ORIN_SKIP_STARTUP_VALIDATION=1 common.
# - Staging: real keys in a secret manager; Redis URL points to staging instance.
# - Production: all required keys set; ORIN_SKIP_STARTUP_VALIDATION unset; monitor GET /health.
#
# ---------------------------------------------------------------------------
# ORIN_SKIP_STARTUP_VALIDATION — optional (development / CI)
# Set to 1 to skip strict startup checks in startup_check (faster local/CI).
# Omit or unset in production so missing/broken config fails fast.
# ---------------------------------------------------------------------------
# ORIN_SKIP_STARTUP_VALIDATION=1

# ---------------------------------------------------------------------------
# LLM and tools — required for a real pipeline run (billable)
# ---------------------------------------------------------------------------
# ── Gemini API keys (create free keys at aistudio.google.com — no card needed)
GOOGLE_API_KEY_1=your_google_api_key_account_1
GOOGLE_API_KEY_2=your_google_api_key_account_2
GOOGLE_API_KEY_3=your_google_api_key_account_3
GOOGLE_API_KEY_4=your_google_api_key_account_4

# ── Groq API keys (create free keys at console.groq.com — no card needed)
GROQ_API_KEY_1=your_groq_api_key_account_1
GROQ_API_KEY_2=your_groq_api_key_account_2

# ── Search, sandbox, observability
TAVILY_API_KEY=your_tavily_key
E2B_API_KEY=your_e2b_key
LOGFIRE_TOKEN=your_logfire_token

# ---------------------------------------------------------------------------
# Redis — recommended for run status / artifacts across restarts
# Default works for local dev with Redis on localhost or Docker Compose redis service.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Live-only tests (optional)
# Set ORIN_LIVE_SELF_HEALING=1 plus real keys to run tests/test_self_healing.py stack tests.
# ---------------------------------------------------------------------------
# ORIN_LIVE_SELF_HEALING=1
