# =============================================================================
# Orin AI — environment template
# Copy to backend/.env (see orin-ai/README.md). Never commit real secrets.
# =============================================================================
#
# ENVIRONMENT TIERS (see README.md "Environments")
# - Development: placeholders or test keys OK; ORIN_SKIP_STARTUP_VALIDATION=1 common.
# - Staging: real keys in a secret manager; Redis URL points to staging instance.
# - Production: all required keys set; ORIN_SKIP_STARTUP_VALIDATION unset; monitor GET /health.
#
# ---------------------------------------------------------------------------
# ORIN_SKIP_STARTUP_VALIDATION — optional (development / CI)
# Set to 1 to skip strict startup checks in startup_check (faster local/CI).
# Omit or unset in production so missing/broken config fails fast.
# ---------------------------------------------------------------------------
# ORIN_SKIP_STARTUP_VALIDATION=1

# ---------------------------------------------------------------------------
# LLM and tools — required for a real pipeline run (billable)
# ---------------------------------------------------------------------------
# ── Groq API keys (console.groq.com) — routing:
#   GROQ_API_KEY_1: Supervisor + Researcher (llama-3.3-70b-versatile)
#   GROQ_API_KEY_2: Architect (llama-3.3-70b-versatile)
#   GROQ_API_KEY_3: Developer + Critic (llama-3.3-70b-versatile)
#   GROQ_API_KEY_4: Persona + Auditor (llama-3.1-8b-instant)
GROQ_API_KEY_1=your_groq_key_1
GROQ_API_KEY_2=your_groq_key_2
GROQ_API_KEY_3=your_groq_key_3
GROQ_API_KEY_4=your_groq_key_4

# ── Search, sandbox, observability
TAVILY_API_KEY=your_tavily_key
E2B_API_KEY=your_e2b_key
LOGFIRE_TOKEN=your_logfire_token

# ---------------------------------------------------------------------------
# CORS — optional production UI origins (comma-separated). Localhost/127.0.0.1:any port is always allowed.
# ALLOWED_ORIGINS=https://your-app.example.com
#
# Frontend (local `npm run dev` only): optional override for Next.js /api proxy — default http://127.0.0.1:8000
# Put in orin-ai/frontend/.env.local — not used by Docker (image build uses Dockerfile ARG BACKEND_URL).
# BACKEND_URL=http://127.0.0.1:8000
#
# ---------------------------------------------------------------------------
# Redis — recommended for run status / artifacts across restarts
# Default works for local dev with Redis on localhost or Docker Compose redis service.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Docker Compose — if "address already in use" on host port 3000 (e.g. local next dev)
# Set in orin-ai/.env or export for one run: FRONTEND_HOST_PORT=3001 docker compose up
# ---------------------------------------------------------------------------
# FRONTEND_HOST_PORT=3001

# ---------------------------------------------------------------------------
# API / pipeline tuning (optional)
# ORIN_MAX_CONCURRENT_RUNS=5        # POST /run concurrency (default 5)
# ORIN_QUEUE_DRAIN_SEC=15         # Seconds to keep SSE queue after run ends, then drop (default 15; 0 = immediate)
# ORIN_SSE_MAX_SEC=1800           # Max wall time for one SSE connection (default 1800)
# ORIN_MAX_RUN_BODY_BYTES=65536   # Reject POST /run bodies larger than this (default 65536)
# ORIN_GROQ_BACKOFF_CAP_SEC=8     # Cap each Groq rate-limit sleep (default 8)
# ORIN_GROQ_LOOP_THREAD_SLEEP_CAP_SEC=0.25  # When rate-limit retry runs on asyncio thread, cap sleep (default 0.25)
# ORIN_MAX_AUDIT_LOOPS=4          # Max auditor→developer remediation rounds before FAILED (default 4)

# ---------------------------------------------------------------------------
# Live-only tests (optional)
# Set ORIN_LIVE_SELF_HEALING=1 plus real keys to run tests/test_self_healing.py stack tests.
# ---------------------------------------------------------------------------
# ORIN_LIVE_SELF_HEALING=1
